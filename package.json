{
  "name": "claude-code",
  "version": "6.6.6-taylor's-version",
  "private": true,
  "type": "module",
  "bin": {
    "claudio": "src/index.ts"
  },
  "scripts": {
    "start": "bun run --feature=BUDDY src/index.ts",
    "postinstall": "bash scripts/postinstall.sh",
    "build": "bun build src/index.ts --bundle --target=bun --outfile=dist/bundle.js && node scripts/patch-bundle.js",
    "build:win": "bun build src/index.ts --bundle --target=bun --outfile=dist/bundle.js && node scripts/patch-bundle.js && bun build dist/bundle.js --compile --target=bun-windows-x64 --outfile dist/claudio.exe",
    "build:linux": "bun build src/index.ts --bundle --target=bun --outfile=dist/bundle.js && node scripts/patch-bundle.js && bun build dist/bundle.js --compile --target=bun-linux-x64 --outfile dist/claudio-linux",
    "build:mac": "bun build src/index.ts --bundle --target=bun --outfile=dist/bundle.js && node scripts/patch-bundle.js && bun build dist/bundle.js --compile --target=bun-darwin-arm64 --outfile dist/claudio-mac",
    "dev": "bun run --feature=BUDDY src/index.ts"
  },
  "dependencies": {
    "@alcalzone/ansi-tokenize": "^0.1.0",
    "@anthropic-ai/bedrock-sdk": "*",
    "@anthropic-ai/foundry-sdk": "*",
    "@anthropic-ai/mcpb": "*",
